    else:
        print("turns: none yet")


def _print_neurobus() -> None:
    import json as _json
    from pathlib import Path as _Path
    nb_path = _Path(os.getenv("AEGIS_STATE_DIR", "/var/lib/aegis")) / "neurobus_state.json"
    if not nb_path.exists():
        print("neurobus: unknown (state file missing)")
        return
    try:
        nb = _json.loads(nb_path.read_text())
        for k in ["reward", "novelty", "attention", "patience", "threat", "trust"]:
            print(f"{k:<10} {nb.get(k, 0):.4f}")
        print(f"{'updated':<10} {nb.get('updated_at', '?')}")
    except Exception as e:
        print(f"neurobus: error — {e}")


def _print_mem(n: int) -> None:
    from pathlib import Path as _Path
    from datetime import datetime as _dt, timezone as _tz
    import sqlite3
    db_path = _Path.home() / ".local" / "share" / "aegis" / "mnemosyne.db"
    if not db_path.exists():
        print("memory: unknown (db missing)")
        return
    conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
    rows = conn.execute("SELECT id, ts, action, text FROM episodes ORDER BY id DESC LIMIT ?", (n,)).fetchall()
    conn.close()
    ts = lambda t: _dt.fromtimestamp(t, tz=_tz.utc).isoformat() if t else "?"
    label = lambda a: "seed" if a == "seed" else ("AEGIS" if a == "speak" else "USER")
    for _id, _ts, action, text in reversed(rows):
        print(f"#{_id} {label(action)} {ts(_ts)} {text[:120]}")

# B2 observability flags — parse before socket connection.
import sys as _sys
_args = [a for a in _sys.argv[1:] if not a.startswith("-")]
_flags = [a for a in _sys.argv[1:] if a.startswith("-")]

if "--health" in _flags:
    _print_health()
    _sys.exit(0)
if "--neurobus" in _flags:
    _print_neurobus()
    _sys.exit(0)
if any(f.startswith("--mem") for f in _flags):
    _mem_flag = next((f for f in _flags if f.startswith("--mem")), None)
    _n = 10
    if _mem_flag and "=" in _mem_flag:
        _n = int(_mem_flag.split("=", 1)[1])
    elif _mem_flag:
        idx = _sys.argv.index(_mem_flag)
        if idx + 1 < len(_sys.argv):
            _n = int(_sys.argv[idx + 1])
    _print_mem(_n)
    _sys.exit(0)



