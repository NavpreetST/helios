def _print_health() -> None:
    import json as _json
    from pathlib import Path as _Path
    import subprocess as _sp

    sock_path = _Path("/run/aegis/aegis.sock")
    sock_ok = sock_path.exists()
    pid_out = ""
    try:
        pid_out = _sp.run(["pgrep", "-f", "python -m aegis.main"], capture_output=True, text=True, timeout=2).stdout.strip()
    except Exception:
        pass

    state_dir = _Path(os.getenv("AEGIS_STATE_DIR", "/var/lib/aegis"))
    print("aegis health:", "ok" if sock_ok else "degraded")
    print(f"daemon: {'pid ' + pid_out if pid_out else 'not found'}, socket {'present' if sock_ok else 'MISSING'}")

    rs_path = state_dir / "renderer_state.json"
    if rs_path.exists():
        try:
            rs = _json.loads(rs_path.read_text())
            chain = rs.get("chain", [])
            ls = rs.get("last_success", {})
            lf = rs.get("last_fallback")
            gem = rs.get("providers", {}).get("gemini", {})
            print(f"renderer: chain {' -> '.join(chain)}, last_success={ls.get('provider', '?')}")
            print(f"quota: gemini {gem.get('local_daily_used','?')}/{gem.get('local_daily_budget','?')}")
            if lf:
                print(f"last_fallback: {lf.get('from')} -> {lf.get('to')} ({lf.get('reason')})")
        except Exception as e:
            print(f"renderer: error — {e}")
    else:
        print("renderer: unknown")

    db_path = _Path.home() / ".local" / "share" / "aegis" / "mnemosyne.db"
    if db_path.exists():
        try:
            import sqlite3
            conn = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
            total = conn.execute("SELECT COUNT(*) FROM episodes").fetchone()[0]
            seeds = conn.execute("SELECT COUNT(*) FROM episodes WHERE action='seed'").fetchone()[0]
            conn.close()
            print(f"memory: {total} episodes, {seeds} seed rows")
        except Exception as e:
            print(f"memory: error — {e}")
    else:
        print("memory: unknown")

    nb_path = state_dir / "neurobus_state.json"
    if nb_path.exists():
        try:
            nb = _json.loads(nb_path.read_text())
            print(f"neurobus: reward={nb.get('reward',0):.2f} novelty={nb.get('novelty',0):.2f} attention={nb.get('attention',0):.2f} patience={nb.get('patience',0):.2f} threat={nb.get('threat',0):.2f} trust={nb.get('trust',0):.2f}")
        except Exception as e:
            print(f"neurobus: error — {e}")
    else:
        print("neurobus: unknown")

    turns_path = state_dir / "turns.jsonl"
    if turns_path.exists():
        try:
            result = _sp.run(["tail", "-1", str(turns_path)], capture_output=True, text=True, timeout=2)
            if result.stdout.strip():
                row = _json.loads(result.stdout.strip())
                print(f"turns: last provider={row.get('provider','?')} render_ms={row.get('render_ms','?')} total_ms={row.get('total_ms','?')} fallback={row.get('fallback_fired','?')}")
            else:
                print("turns: empty")
        except Exception as e:
