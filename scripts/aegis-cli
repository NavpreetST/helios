#!/usr/bin/env python3
"""Aegis CLI — unix socket client.

Default socket resolution: env $AEGIS_SOCK → /run/aegis/aegis.sock (prod) →
/tmp/aegis.sock (foreground dev). First existing path wins.

Usage:
    aegis                 # interactive
    echo "hi" | aegis     # one-shot
"""
import os
import socket
import sys
import threading
import time
from pathlib import Path

DEFAULTS = ["/run/aegis/aegis.sock", "/tmp/aegis.sock"]


def _resolve_sock() -> str:
    env = os.getenv("AEGIS_SOCK")
    if env:
        return env
    for p in DEFAULTS:
        if Path(p).exists():
            return p
    return DEFAULTS[0]


SOCK = _resolve_sock()

try:
    s = socket.socket(socket.AF_UNIX)
    s.connect(SOCK)
except (FileNotFoundError, ConnectionRefusedError, PermissionError) as e:
    print(f"aegis: service not running at {SOCK} ({e})", file=sys.stderr)
    sys.exit(1)


def _reader() -> None:
    f = s.makefile("r", encoding="utf-8", errors="replace")
    for line in f:
        print(line, end="", flush=True)


threading.Thread(target=_reader, daemon=True).start()

if sys.stdin.isatty():
    try:
        for line in sys.stdin:
            s.sendall(line.encode())
    except (KeyboardInterrupt, BrokenPipeError):
        pass
else:
    data = sys.stdin.read().encode()
    if not data.endswith(b"\n"):
        data += b"\n"
    s.sendall(data)
    time.sleep(6.0)   # wait for the reply line
s.close()
